<div class="max-w-2xl mx-auto px-6 py-24 text-center">
  <h1 class="text-[126px] font-black leading-[107.1px] text-[#d4ddd0] dark:text-[#181a16] mb-4">500</h1>
  <h2 class="text-[24px] font-semibold tracking-[-0.48px] text-[#0e0f0c] dark:text-[#e8ebe6] mb-4">Server Error</h2>
  <p class="text-base text-[#454745] dark:text-[#868685] mb-8">Something went wrong on our end. Please try again later.</p>
  <a href="/" class="inline-flex items-center px-6 py-3 rounded-3xl bg-[#9fe870] text-[#0e0f0c] font-semibold hover:bg-[#cdffad] transition-colors duration-200">Go Home</a>
  <% if (locals.error) { %>
    <pre class="mt-8 text-left bg-white dark:bg-[#1a1c18] rounded-3xl p-6 overflow-x-auto text-xs text-[#d03238] dark:text-[#d03238]"><%= error.stack %></pre>
  <% } %>
</div>
