<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
  <h1 class="text-6xl font-extrabold text-slate-300 dark:text-slate-600 mb-4">500</h1>
  <h2 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-4">Server Error</h2>
  <p class="text-slate-500 dark:text-slate-400 mb-8">Something went wrong on our end. Please try again later.</p>
  <a href="/" class="inline-flex items-center px-6 py-3 rounded-xl bg-sky-500 text-white font-medium hover:bg-sky-600 transition-colors duration-200 shadow-sm">Go Home</a>
  <% if (locals.error) { %>
    <pre class="mt-8 text-left bg-slate-100 dark:bg-slate-800 rounded-xl p-4 overflow-x-auto text-xs text-red-600 dark:text-red-400"><%= error.stack %></pre>
  <% } %>
</div>
