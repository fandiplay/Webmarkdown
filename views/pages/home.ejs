<div class="max-w-6xl mx-auto px-6 py-16 sm:py-24">
  <!-- Hero -->
  <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16 mb-20">
    <div class="flex-1 text-center md:text-left">
      <h1 class="text-[64px] sm:text-[96px] font-black leading-[54.4px] sm:leading-[81.6px] text-[#0e0f0c] dark:text-[#e8ebe6] mb-6">
        Hi, I'm <span class="text-[#9fe870]"><%= config.fullName %></span>
      </h1>
      <p class="text-xl text-[#454745] dark:text-[#c8cac5] mb-2 font-normal"><%= config.occupation %></p>
      <p class="text-base text-[#454745] dark:text-[#868685] max-w-lg mx-auto md:mx-0"><%= config.bio %></p>
    </div>
    <div class="shrink-0">
      <img src="<%= config.avatar %>" alt="<%= config.fullName %>" class="w-48 h-48 sm:w-56 sm:h-56 rounded-3xl object-cover ring-4 ring-[#9fe870]/30">
    </div>
  </div>

  <!-- Operational DNA -->
  <section class="mb-20">
    <h2 class="text-[40px] font-black leading-[34px] text-[#0e0f0c] dark:text-[#e8ebe6] mb-8">Operational DNA</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-white dark:bg-[#1a1c18] rounded-3xl p-6 hover:shadow-md hover:-translate-y-1 transition-all duration-300">
        <div class="w-10 h-10 rounded-xl bg-[#e2f6d5] dark:bg-[#163300] flex items-center justify-center mb-3"><i data-lucide="user" class="w-5 h-5 text-[#054d28] dark:text-[#9fe870]"></i></div>
        <h3 class="font-semibold text-[#0e0f0c] dark:text-[#e8ebe6] mb-1">Who Am I</h3>
        <p class="text-sm text-[#454745] dark:text-[#868685]">A passionate software engineer who loves turning ideas into reality through code.</p>
      </div>
      <div class="bg-white dark:bg-[#1a1c18] rounded-3xl p-6 hover:shadow-md hover:-translate-y-1 transition-all duration-300">
        <div class="w-10 h-10 rounded-xl bg-[#e2f6d5] dark:bg-[#163300] flex items-center justify-center mb-3"><i data-lucide="briefcase" class="w-5 h-5 text-[#054d28] dark:text-[#9fe870]"></i></div>
        <h3 class="font-semibold text-[#0e0f0c] dark:text-[#e8ebe6] mb-1">Occupation</h3>
        <p class="text-sm text-[#454745] dark:text-[#868685]">Building full-stack web applications and distributed systems.</p>
      </div>
      <div class="bg-white dark:bg-[#1a1c18] rounded-3xl p-6 hover:shadow-md hover:-translate-y-1 transition-all duration-300">
        <div class="w-10 h-10 rounded-xl bg-[#e2f6d5] dark:bg-[#163300] flex items-center justify-center mb-3"><i data-lucide="heart" class="w-5 h-5 text-[#054d28] dark:text-[#9fe870]"></i></div>
        <h3 class="font-semibold text-[#0e0f0c] dark:text-[#e8ebe6] mb-1">Hobbies</h3>
        <p class="text-sm text-[#454745] dark:text-[#868685]">Photography, hiking, reading sci-fi, and experimenting with new tech.</p>
      </div>
      <div class="bg-white dark:bg-[#1a1c18] rounded-3xl p-6 hover:shadow-md hover:-translate-y-1 transition-all duration-300">
        <div class="w-10 h-10 rounded-xl bg-[#e2f6d5] dark:bg-[#163300] flex items-center justify-center mb-3"><i data-lucide="sparkles" class="w-5 h-5 text-[#054d28] dark:text-[#9fe870]"></i></div>
        <h3 class="font-semibold text-[#0e0f0c] dark:text-[#e8ebe6] mb-1">Interests</h3>
        <p class="text-sm text-[#454745] dark:text-[#868685]">Open source, Rust, distributed systems, and developer tooling.</p>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <% if (featuredProjects && featuredProjects.length) { %>
  <section class="mb-20">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-[40px] font-black leading-[34px] text-[#0e0f0c] dark:text-[#e8ebe6]">Portfolio Projects</h2>
      <span class="text-xs text-[#868685] font-semibold uppercase tracking-wider">Featured</span>
    </div>
    <div class="grid sm:grid-cols-2 gap-6">
      <% featuredProjects.forEach(function(p) { %>
        <%- include('../partials/project-card', { project: p }) %>
      <% }); %>
    </div>
  </section>
  <% } %>

  <!-- Latest Posts -->
  <% if (latestPosts && latestPosts.length) { %>
  <section>
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-[40px] font-black leading-[34px] text-[#0e0f0c] dark:text-[#e8ebe6]">Recent Publications</h2>
      <a href="/blog" class="text-sm font-semibold text-[#0e0f0c] dark:text-[#e8ebe6] hover:text-[#163300] dark:hover:text-[#9fe870] transition-colors">View all &rarr;</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% latestPosts.forEach(function(p) { %>
        <%- include('../partials/post-card', { post: p }) %>
      <% }); %>
    </div>
  </section>
  <% } %>
</div>
