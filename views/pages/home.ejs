<div class="relative isolate overflow-hidden max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14 lg:py-16">
  <!-- Glow background -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-24 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-[#9fe870]/30 blur-3xl"></div>
    <div class="absolute top-32 -left-16 h-64 w-64 rounded-full bg-[#b7f3ff]/20 blur-3xl dark:bg-[#163300]/35"></div>
    <div class="absolute bottom-10 right-0 h-80 w-80 rounded-full bg-[#d7ff7a]/20 blur-3xl dark:bg-[#9fe870]/10"></div>
  </div>

  <!-- Hero -->
  <section class="grid items-center gap-8 lg:grid-cols-[1.25fr_0.75fr] lg:gap-12 mb-16 sm:mb-20 lg:mb-24">
    <div class="relative rounded-[2rem] border border-white/70 bg-white/75 p-6 sm:p-8 shadow-[0_24px_80px_rgba(14,15,12,0.10)] backdrop-blur-xl dark:border-white/10 dark:bg-[#0e0f0c]/70 dark:shadow-[0_24px_80px_rgba(0,0,0,0.35)]">
      <div class="mb-5 flex flex-wrap items-center gap-2">
        <span class="inline-flex items-center gap-2 rounded-full bg-[#e2f6d5] px-3 py-1 text-xs font-semibold text-[#054d28] dark:bg-[#163300] dark:text-[#9fe870]">
          <span class="h-2 w-2 rounded-full bg-[#9fe870] shadow-[0_0_18px_rgba(159,232,112,0.95)]"></span>
          Personal portfolio
        </span>
        <span class="inline-flex items-center rounded-full border border-[#dfe5dc] bg-white/80 px-3 py-1 text-xs font-medium text-[#454745] dark:border-white/10 dark:bg-white/5 dark:text-[#c8cac5]">
          Clean layout · stronger glow · easier reading
        </span>
      </div>

      <div class="grid items-center gap-8 md:grid-cols-[1.15fr_0.85fr]">
        <div class="text-center md:text-left">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-[#868685] dark:text-[#6b6b6a]">
            Hello, I'm
          </p>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-[0.92] tracking-tight text-[#0e0f0c] dark:text-[#e8ebe6]">
            <span class="relative inline-block">
              <span class="absolute inset-0 -z-10 blur-2xl text-[#9fe870]"> <%= config.fullName %> </span>
              <span class="bg-gradient-to-r from-[#0e0f0c] via-[#163300] to-[#9fe870] bg-clip-text text-transparent dark:from-[#e8ebe6] dark:via-[#9fe870] dark:to-[#bff59d]">
                <%= config.fullName %>
              </span>
            </span>
          </h1>

          <p class="mt-5 text-xl font-medium text-[#163300] dark:text-[#9fe870]">
            <%= config.occupation %>
          </p>

          <p class="mt-4 max-w-2xl text-base leading-7 text-[#454745] dark:text-[#c8cac5]">
            <%= config.bio %>
          </p>

          <div class="mt-7 flex flex-wrap items-center justify-center md:justify-start gap-3">
            <span class="rounded-full bg-[#f3f7f0] px-4 py-2 text-sm font-medium text-[#454745] ring-1 ring-[#dfe5dc] dark:bg-white/5 dark:text-[#c8cac5] dark:ring-white/10">Readable structure</span>
            <span class="rounded-full bg-[#f3f7f0] px-4 py-2 text-sm font-medium text-[#454745] ring-1 ring-[#dfe5dc] dark:bg-white/5 dark:text-[#c8cac5] dark:ring-white/10">Bright glow accents</span>
            <span class="rounded-full bg-[#f3f7f0] px-4 py-2 text-sm font-medium text-[#454745] ring-1 ring-[#dfe5dc] dark:bg-white/5 dark:text-[#c8cac5] dark:ring-white/10">Comfortable spacing</span>
          </div>
        </div>

        <div class="relative mx-auto w-full max-w-[320px]">
          <div class="absolute inset-0 rounded-[2rem] bg-[#9fe870]/30 blur-3xl"></div>
          <div class="relative overflow-hidden rounded-[2rem] border border-white/70 bg-white/80 p-4 shadow-[0_24px_80px_rgba(14,15,12,0.14)] backdrop-blur-xl dark:border-white/10 dark:bg-[#1a1c18]/80">
            <img
              src="<%= config.avatar %>"
              alt="<%= config.fullName %>"
              class="aspect-square w-full rounded-[1.5rem] object-cover ring-1 ring-[#9fe870]/40 shadow-[0_0_0_8px_rgba(159,232,112,0.10)]"
            >
            <div class="mt-4 flex items-center justify-between gap-3 rounded-2xl bg-[#f5f8f2] px-4 py-3 dark:bg-white/5">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#868685] dark:text-[#6b6b6a]">Focus</p>
                <p class="text-sm font-semibold text-[#0e0f0c] dark:text-[#e8ebe6]">Build, refine, ship</p>
              </div>
              <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[#e2f6d5] text-[#054d28] shadow-[0_0_24px_rgba(159,232,112,0.35)] dark:bg-[#163300] dark:text-[#9fe870]">
                <i data-lucide="sparkles" class="h-5 w-5"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Operational DNA -->
  <section class="mb-16 sm:mb-20 lg:mb-24">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.24em] text-[#868685] dark:text-[#6b6b6a]">Operational DNA</p>
        <h2 class="text-3xl sm:text-4xl font-black leading-tight text-[#0e0f0c] dark:text-[#e8ebe6]">What this portfolio is built around</h2>
      </div>
      <div class="hidden sm:block h-px flex-1 bg-gradient-to-r from-[#9fe870]/0 via-[#9fe870]/60 to-[#9fe870]/0"></div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      <div class="group rounded-[1.75rem] border border-white/70 bg-white/80 p-6 shadow-[0_20px_50px_rgba(14,15,12,0.08)] backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(159,232,112,0.18)] dark:border-white/10 dark:bg-[#1a1c18]/80">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-[#e2f6d5] text-[#054d28] shadow-[0_0_24px_rgba(159,232,112,0.28)] dark:bg-[#163300] dark:text-[#9fe870]">
          <i data-lucide="user" class="h-5 w-5"></i>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-[#0e0f0c] dark:text-[#e8ebe6]">Who Am I</h3>
        <p class="text-sm leading-6 text-[#454745] dark:text-[#c8cac5]">A passionate software engineer who loves turning ideas into reality through code.</p>
      </div>

      <div class="group rounded-[1.75rem] border border-white/70 bg-white/80 p-6 shadow-[0_20px_50px_rgba(14,15,12,0.08)] backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(159,232,112,0.18)] dark:border-white/10 dark:bg-[#1a1c18]/80">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-[#e2f6d5] text-[#054d28] shadow-[0_0_24px_rgba(159,232,112,0.28)] dark:bg-[#163300] dark:text-[#9fe870]">
          <i data-lucide="briefcase" class="h-5 w-5"></i>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-[#0e0f0c] dark:text-[#e8ebe6]">Occupation</h3>
        <p class="text-sm leading-6 text-[#454745] dark:text-[#c8cac5]">Building full-stack web applications and distributed systems.</p>
      </div>

      <div class="group rounded-[1.75rem] border border-white/70 bg-white/80 p-6 shadow-[0_20px_50px_rgba(14,15,12,0.08)] backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(159,232,112,0.18)] dark:border-white/10 dark:bg-[#1a1c18]/80">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-[#e2f6d5] text-[#054d28] shadow-[0_0_24px_rgba(159,232,112,0.28)] dark:bg-[#163300] dark:text-[#9fe870]">
          <i data-lucide="heart" class="h-5 w-5"></i>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-[#0e0f0c] dark:text-[#e8ebe6]">Hobbies</h3>
        <p class="text-sm leading-6 text-[#454745] dark:text-[#c8cac5]">Photography, hiking, reading sci-fi, and experimenting with new tech.</p>
      </div>

      <div class="group rounded-[1.75rem] border border-white/70 bg-white/80 p-6 shadow-[0_20px_50px_rgba(14,15,12,0.08)] backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(159,232,112,0.18)] dark:border-white/10 dark:bg-[#1a1c18]/80">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-[#e2f6d5] text-[#054d28] shadow-[0_0_24px_rgba(159,232,112,0.28)] dark:bg-[#163300] dark:text-[#9fe870]">
          <i data-lucide="sparkles" class="h-5 w-5"></i>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-[#0e0f0c] dark:text-[#e8ebe6]">Interests</h3>
        <p class="text-sm leading-6 text-[#454745] dark:text-[#c8cac5]">Open source, Rust, distributed systems, and developer tooling.</p>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <% if (featuredProjects && featuredProjects.length) { %>
  <section class="mb-16 sm:mb-20 lg:mb-24">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.24em] text-[#868685] dark:text-[#6b6b6a]">Featured work</p>
        <h2 class="text-3xl sm:text-4xl font-black leading-tight text-[#0e0f0c] dark:text-[#e8ebe6]">Portfolio Projects</h2>
      </div>
      <span class="inline-flex items-center rounded-full bg-[#e2f6d5] px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-[#054d28] dark:bg-[#163300] dark:text-[#9fe870]">
        Featured
      </span>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      <% featuredProjects.forEach(function(p) { %>
        <%- include('../partials/project-card', { project: p }) %>
      <% }); %>
    </div>
  </section>
  <% } %>

  <!-- Latest Posts -->
  <% if (latestPosts && latestPosts.length) { %>
  <section>
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.24em] text-[#868685] dark:text-[#6b6b6a]">Latest writing</p>
        <h2 class="text-3xl sm:text-4xl font-black leading-tight text-[#0e0f0c] dark:text-[#e8ebe6]">Recent Publications</h2>
      </div>
      <a href="/blog" class="inline-flex items-center gap-2 rounded-full border border-[#dfe5dc] bg-white/80 px-4 py-2 text-sm font-semibold text-[#0e0f0c] shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-[#9fe870] hover:text-[#163300] hover:shadow-[0_0_24px_rgba(159,232,112,0.20)] dark:border-white/10 dark:bg-white/5 dark:text-[#e8ebe6] dark:hover:border-[#9fe870] dark:hover:text-[#9fe870]">
        View all <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% latestPosts.forEach(function(p) { %>
        <%- include('../partials/post-card', { post: p }) %>
      <% }); %>
    </div>
  </section>
  <% } %>
</div>
