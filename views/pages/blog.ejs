<div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
  <style>
    .blog-shell {
      position: relative;
    }.blog-shell::before {
  content: "";
  position: absolute;
  inset: -24px -16px auto -16px;
  height: 240px;
  background:
    radial-gradient(circle at top left, rgba(159, 232, 112, 0.16), transparent 55%),
    radial-gradient(circle at top right, rgba(22, 51, 0, 0.08), transparent 45%);
  pointer-events: none;
  z-index: 0;
}

.dark .blog-shell::before {
  background:
    radial-gradient(circle at top left, rgba(159, 232, 112, 0.10), transparent 55%),
    radial-gradient(circle at top right, rgba(159, 232, 112, 0.05), transparent 45%);
}

.blog-content {
  position: relative;
  z-index: 1;
}

.blog-more-backdrop {
  backdrop-filter: blur(10px);
}

.blog-card {
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.blog-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 16px 40px rgba(14, 15, 12, 0.08);
}

.dark .blog-card:hover {
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
}

.soft-surface {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
}

.dark .soft-surface {
  background: rgba(26, 28, 24, 0.72);
}

.tag-chip {
  transition: transform 0.15s ease, background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
}

.tag-chip:hover {
  transform: translateY(-1px);
}

.tag-chip-active {
  box-shadow: 0 0 0 1px rgba(159, 232, 112, 0.14), 0 10px 30px rgba(159, 232, 112, 0.16);
}

.input-clean {
  box-shadow: 0 1px 2px rgba(14, 15, 12, 0.04);
}

.dark .input-clean {
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
}

.modal-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,248,244,0.98));
}

.dark .modal-card {
  background: linear-gradient(180deg, rgba(14,15,12,0.98), rgba(26,28,24,0.98));
}

  </style>  <div class="blog-shell">
    <div class="blog-content">
      <!-- Header -->
      <div class="mb-8 sm:mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[#cfe9bc] dark:border-[#2a2d25] bg-white/70 dark:bg-[#1a1c18]/80 text-xs font-semibold text-[#163300] dark:text-[#9fe870] shadow-sm">
          <span class="inline-block h-2 w-2 rounded-full bg-[#9fe870]"></span>
          Blog
        </div>    <h1 class="mt-4 text-[30px] sm:text-[36px] md:text-[42px] font-semibold leading-tight tracking-[-0.04em] text-[#0e0f0c] dark:text-[#e8ebe6]">
      My Article
    </h1>

    <p class="mt-3 max-w-2xl text-sm sm:text-base leading-6 text-[#5f635d] dark:text-[#868685]">
      A student who enjoys developing websites and reading books on self-improvement.
    </p>
  </div>

  <!-- Search & Sort -->
  <form method="GET" action="/blog" id="search-form">
    <% if (activeTag) { %><input type="hidden" name="tag" value="<%= activeTag %>"><% } %>
    <div class="mb-6 p-3 sm:p-4 rounded-2xl border border-[#dde7d4] dark:border-[#2a2d25] soft-surface shadow-sm">
      <div class="flex flex-col lg:flex-row gap-3">
        <div class="flex-1">
          <label for="search-input" class="sr-only">Search posts</label>
          <div class="relative">
            <!-- Tombol search DI KANAN dengan bentuk rounded-full -->
            <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center rounded-full bg-[#9fe870] text-[#0e0f0c] hover:bg-[#8ce45a] dark:bg-[#9fe870]/20 dark:text-[#9fe870] dark:hover:bg-[#9fe870]/30 transition-colors duration-200 shadow-sm" aria-label="Search">
              <i data-lucide="search" class="w-4 h-4"></i>
            </button>
            <!-- Input type="search" agar keyboard HP menampilkan tombol Search -->
            <input
              type="search"
              id="search-input"
              name="search"
              value="<%= activeSearch || '' %>"
              placeholder="Search posts..."
              autocomplete="off"
              class="input-clean w-full pl-4 pr-14 py-3 rounded-xl border border-[#d7e3cb] dark:border-[#454745] bg-white/90 dark:bg-[#1a1c18] text-[#0e0f0c] dark:text-[#e8ebe6] placeholder-[#868685] text-sm sm:text-base focus:outline-none focus:ring-2 focus:ring-[#9fe870]/45 transition-all duration-200"
            >
          </div>
        </div>

        <div class="w-full lg:w-56">
          <label for="sort-select" class="sr-only">Sort posts</label>
          <div class="relative">
            <i data-lucide="arrow-up-down" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#868685]"></i>
            <select
              id="sort-select"
              name="sort"
              onchange="this.form.submit()"
              class="input-clean w-full appearance-none pl-11 pr-10 py-3 rounded-xl border border-[#d7e3cb] dark:border-[#454745] bg-white/90 dark:bg-[#1a1c18] text-[#0e0f0c] dark:text-[#e8ebe6] text-sm sm:text-base focus:outline-none focus:ring-2 focus:ring-[#9fe870]/45 transition-all duration-200"
            >
              <option value="newest" <%= activeSort === 'newest' ? 'selected' : '' %>>Newest First</option>
              <option value="oldest" <%= activeSort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
            </select>
            <i data-lucide="chevron-down" class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#868685]"></i>
          </div>
        </div>
      </div>
    </div>
  </form>

  <!-- Tags -->
  <% if ((tags && tags.length) || (hiddenTags && hiddenTags.length)) { %>
  <div class="mb-8">
    <div class="flex flex-wrap items-center gap-2">
      <a
        href="/blog"
        class="tag-chip px-3.5 py-1.5 rounded-full text-xs font-semibold border <%= !activeTag ? 'bg-[#9fe870] text-[#0e0f0c] border-[#9fe870] tag-chip-active' : 'bg-white/80 dark:bg-[#1a1c18] text-[#5f635d] dark:text-[#868685] border-[#dde7d4] dark:border-[#2a2d25] hover:bg-[#eef8e6] dark:hover:bg-[#23261f] hover:text-[#163300] dark:hover:text-[#e8ebe6]' %>"
      >
        All
      </a>

      <% (tags || []).forEach(function(tag) { %>
        <a
          href="/blog?tag=<%= tag %>"
          class="tag-chip px-3.5 py-1.5 rounded-full text-xs font-semibold border <%= activeTag === tag ? 'bg-[#9fe870] text-[#0e0f0c] border-[#9fe870] tag-chip-active' : 'bg-white/80 dark:bg-[#1a1c18] text-[#5f635d] dark:text-[#868685] border-[#dde7d4] dark:border-[#2a2d25] hover:bg-[#eef8e6] dark:hover:bg-[#23261f] hover:text-[#163300] dark:hover:text-[#e8ebe6]' %>"
        ><%= tag %></a>
      <% }); %>

      <% if (hiddenTags && hiddenTags.length) { %>
        <button
          type="button"
          onclick="toggleMoreTags()"
          id="more-tags-btn"
          class="tag-chip px-3.5 py-1.5 rounded-full text-xs font-semibold border border-[#0e0f0c] dark:border-[#2a2d25] bg-[#0e0f0c] dark:bg-[#1a1c18] text-[#e8ebe6] dark:text-[#c8cac5] hover:bg-[#163300] hover:border-[#163300] transition-all duration-200"
        >
          More <span id="more-tags-arrow" class="inline-block transition-transform duration-200">▾</span>
        </button>
      <% } %>
    </div>
  </div>

  <% if (hiddenTags && hiddenTags.length) { %>
    <div
      id="more-tags-layer"
      class="fixed inset-0 z-50 hidden items-center justify-center px-4 sm:px-6"
      aria-hidden="true"
    >
      <div
        class="absolute inset-0 bg-black/45 blog-more-backdrop"
        onclick="closeMoreTags()"
      ></div>

      <div class="relative z-10 w-[min(94vw,32rem)] max-w-full rounded-[1.5rem] border border-[#dce7d2] dark:border-[#2a2d25] modal-card shadow-[0_25px_80px_rgba(0,0,0,0.28)] overflow-hidden">
        <div class="flex items-center justify-between px-4 sm:px-5 py-4 border-b border-[#e7eee0] dark:border-[#1f221d]">
          <div>
            <p class="text-sm font-semibold text-[#0e0f0c] dark:text-[#e8ebe6]">More categories</p>
            <p class="text-xs text-[#6e726b] dark:text-[#868685]">Pilih kategori lain tanpa meninggalkan halaman.</p>
          </div>
          <button
            type="button"
            onclick="closeMoreTags()"
            class="px-3 py-1.5 rounded-full text-xs font-semibold border border-[#dce7d2] dark:border-[#2a2d25] bg-white dark:bg-[#1a1c18] text-[#0e0f0c] dark:text-[#c8cac5] hover:bg-[#eef8e6] dark:hover:bg-[#23261f] transition-colors"
          >
            Close
          </button>
        </div>

        <div class="max-h-[54vh] overflow-y-auto p-3 sm:p-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <% hiddenTags.forEach(function(tag) { %>
              <a
                href="/blog?tag=<%= tag %>"
                class="block rounded-2xl px-4 py-3 text-sm font-medium border transition-all duration-200 <%= activeTag === tag ? 'bg-[#edfbe3] dark:bg-[#163300] text-[#163300] dark:text-[#9fe870] border-[#9fe870] shadow-[0_0_18px_rgba(159,232,112,0.10)]' : 'bg-white dark:bg-[#151815] text-[#454745] dark:text-[#c8cac5] border-[#e0ead7] dark:border-[#23261f] hover:bg-[#f3f9ee] dark:hover:bg-[#1a1c18] hover:text-[#163300] dark:hover:text-[#9fe870]' %>"
              ><%= tag %></a>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  <% } %>
  <% } %>

  <!-- Posts Grid -->
  <div id="posts-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
    <% posts.forEach(function(p) { %>
      <div class="post-card blog-card" data-title="<%= p.title.toLowerCase() %>" data-tags="<%= (p.tags || []).join(',').toLowerCase() %>" data-date="<%= p.createdAt %>">
        <%- include('../partials/post-card', { post: p }) %>
      </div>
    <% }); %>
  </div>

  <% if (!posts.length) { %>
    <div class="mt-10 text-center py-14 rounded-3xl border border-dashed border-[#dce7d2] dark:border-[#2a2d25] bg-white/70 dark:bg-[#1a1c18]/70">
      <p class="text-[#0e0f0c] dark:text-[#e8ebe6] font-semibold">No posts found.</p>
      <p class="mt-2 text-sm text-[#6e726b] dark:text-[#868685]">Coba ganti kata kunci atau pilih kategori lain.</p>
    </div>
  <% } %>

  <% if (totalPages > 1) { %>
    <%
      var q = '';
      if (activeTag) q += '&tag=' + encodeURIComponent(activeTag);
      if (activeSort !== 'newest') q += '&sort=' + encodeURIComponent(activeSort);
      if (activeSearch) q += '&search=' + encodeURIComponent(activeSearch);
    %>
    <div class="mt-10 flex items-center justify-center gap-3">
      <% if (currentPage > 1) { %>
        <a href="/blog?page=<%= currentPage - 1 %><%= q %>" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-3xl text-sm font-semibold border border-[#dfe5dc] dark:border-[#2a2d25] bg-white/80 dark:bg-[#1a1c18] text-[#454745] dark:text-[#c8cac5] hover:bg-[#eef8e6] dark:hover:bg-[#23261f] hover:text-[#163300] dark:hover:text-[#e8ebe6] transition-all duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          Prev
        </a>
      <% } else { %>
        <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-3xl text-sm font-semibold border border-[#dfe5dc] dark:border-[#2a2d25] bg-white/40 dark:bg-[#1a1c18]/40 text-[#b0b8ab] dark:text-[#3a3d35] cursor-not-allowed">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          Prev
        </span>
      <% } %>

      <span class="px-3 py-1 text-sm font-medium text-[#6e726b] dark:text-[#868685]">
        Page <%= currentPage %> of <%= totalPages %>
      </span>

      <% if (currentPage < totalPages) { %>
        <a href="/blog?page=<%= currentPage + 1 %><%= q %>" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-3xl text-sm font-semibold border border-[#dfe5dc] dark:border-[#2a2d25] bg-white/80 dark:bg-[#1a1c18] text-[#454745] dark:text-[#c8cac5] hover:bg-[#eef8e6] dark:hover:bg-[#23261f] hover:text-[#163300] dark:hover:text-[#e8ebe6] transition-all duration-200">
          Next
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      <% } else { %>
        <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-3xl text-sm font-semibold border border-[#dfe5dc] dark:border-[#2a2d25] bg-white/40 dark:bg-[#1a1c18]/40 text-[#b0b8ab] dark:text-[#3a3d35] cursor-not-allowed">
          Next
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      <% } %>
    </div>
  <% } %>
</div>

  </div>
</div>

<script>
function toggleMoreTags() {
  var layer = document.getElementById('more-tags-layer');
  var arrow = document.getElementById('more-tags-arrow');

  if (!layer) return;

  var isOpen = !layer.classList.contains('hidden');

  if (isOpen) {
    closeMoreTags();
    return;
  }

  layer.classList.remove('hidden');
  layer.classList.add('flex');
  document.body.style.overflow = 'hidden';
  if (arrow) arrow.style.transform = 'rotate(180deg)';
}

function closeMoreTags() {
  var layer = document.getElementById('more-tags-layer');
  var arrow = document.getElementById('more-tags-arrow');

  if (!layer) return;

  layer.classList.add('hidden');
  layer.classList.remove('flex');
  document.body.style.overflow = '';
  if (arrow) arrow.style.transform = 'rotate(0deg)';
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeMoreTags();
});

// ===== PERBAIKAN UTAMA: semua tombol Enter / Go / Search di keyboard HP & desktop =====
document.addEventListener('DOMContentLoaded', function() {
  var searchInput = document.getElementById('search-input');
  if (searchInput) {
    searchInput.addEventListener('keydown', function(e) {
      // Menangkap Enter (desktop), Go (Android), Search (iOS/type="search"), dan keyCode 13 (universal)
      if (e.key === 'Enter' || e.key === 'Go' || e.key === 'Search' || e.keyCode === 13) {
        e.preventDefault();         // mencegah aksi bawaan (misalnya newline di beberapa browser)
        this.form.submit();         // submit form secara eksplisit
      }
    });
  }
});
</script>