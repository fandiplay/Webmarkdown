<div class="max-w-6xl mx-auto px-6 py-12">
  <style>
    .blog-more-backdrop {
      backdrop-filter: blur(10px);
    }
  </style>

  <div class="mb-8">
    <h1 class="text-[32px] font-semibold leading-[38.4px] tracking-[-0.96px] text-[#0e0f0c] dark:text-[#e8ebe6]">Blog</h1>
    <p class="mt-2 text-sm text-[#868685] dark:text-[#6b6b6a]">
      Topik yang paling sering muncul ditampilkan dulu supaya daftar tidak berantakan.
    </p>
  </div>

  <!-- Search & Sort -->
  <div class="flex flex-col sm:flex-row gap-4 mb-6">
    <div class="flex-1">
      <input
        type="text"
        id="search-input"
        placeholder="Search posts..."
        oninput="filterPosts()"
        class="w-full px-4 py-3 rounded-xl border border-[#0e0f0c] dark:border-[#454745] bg-white dark:bg-[#1a1c18] text-[#0e0f0c] dark:text-[#e8ebe6] placeholder-[#868685] text-base focus:outline-none focus:ring-2 focus:ring-[#9fe870]/50 transition-all duration-200"
      >
    </div>
    <select
      id="sort-select"
      onchange="filterPosts()"
      class="px-4 py-3 rounded-xl border border-[#0e0f0c] dark:border-[#454745] bg-white dark:bg-[#1a1c18] text-[#0e0f0c] dark:text-[#e8ebe6] text-base focus:outline-none focus:ring-2 focus:ring-[#9fe870]/50 transition-all duration-200"
    >
      <option value="newest" <%= activeSort === 'newest' ? 'selected' : '' %>>Newest First</option>
      <option value="oldest" <%= activeSort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
    </select>
  </div>

  <!-- Tags -->
  <% if ((tags && tags.length) || (hiddenTags && hiddenTags.length)) { %>
  <div class="flex flex-wrap items-center gap-2 mb-8">
    <a
      href="/blog"
      class="px-3 py-1.5 rounded-full text-xs font-semibold transition-all duration-200 <%= !activeTag ? 'bg-[#9fe870] text-[#0e0f0c] shadow-[0_0_20px_rgba(159,232,112,0.22)]' : 'bg-[#e8ebe6] dark:bg-[#1a1c18] text-[#454745] dark:text-[#868685] hover:bg-[#e2f6d5] dark:hover:bg-[#2a2d25]' %>"
    >All</a>

    <% (tags || []).forEach(function(tag) { %>
      <a
        href="/blog?tag=<%= tag %>"
        class="px-3 py-1.5 rounded-full text-xs font-semibold transition-all duration-200 <%= activeTag === tag ? 'bg-[#9fe870] text-[#0e0f0c] shadow-[0_0_20px_rgba(159,232,112,0.22)]' : 'bg-[#e8ebe6] dark:bg-[#1a1c18] text-[#454745] dark:text-[#868685] hover:bg-[#e2f6d5] dark:hover:bg-[#2a2d25]' %>"
      ><%= tag %></a>
    <% }); %>

    <% if (hiddenTags && hiddenTags.length) { %>
      <button
        type="button"
        onclick="toggleMoreTags()"
        id="more-tags-btn"
        class="px-3 py-1.5 rounded-full text-xs font-semibold bg-[#1a1c18] text-[#c8cac5] border border-[#2a2d25] hover:bg-[#23261f] hover:text-[#e8ebe6] transition-all duration-200"
      >
        More <span id="more-tags-arrow" class="inline-block transition-transform duration-200">▾</span>
      </button>
    <% } %>
  </div>

  <% if (hiddenTags && hiddenTags.length) { %>
    <div
      id="more-tags-layer"
      class="fixed inset-0 z-50 hidden items-center justify-center px-4 sm:px-6"
      aria-hidden="true"
    >
      <div
        class="absolute inset-0 bg-black/55 blog-more-backdrop"
        onclick="closeMoreTags()"
      ></div>

      <div class="relative z-10 w-[min(92vw,28rem)] max-w-full rounded-[1.6rem] border border-[#2a2d25] bg-[#0e0f0c] shadow-[0_30px_100px_rgba(0,0,0,0.55)] overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-[#1f221d] bg-[#121411]">
          <div>
            <p class="text-sm font-semibold text-[#e8ebe6]">More categories</p>
            <p class="text-xs text-[#868685]">Scroll untuk lihat semua kategori.</p>
          </div>
          <button
            type="button"
            onclick="closeMoreTags()"
            class="px-3 py-1.5 rounded-full text-xs font-semibold text-[#c8cac5] bg-[#1a1c18] hover:bg-[#23261f] hover:text-[#e8ebe6] transition-colors"
          >
            Close
          </button>
        </div>

        <div class="max-h-[52vh] overflow-y-auto p-3">
          <div class="flex flex-col gap-2">
            <% hiddenTags.forEach(function(tag) { %>
              <a
                href="/blog?tag=<%= tag %>"
                class="block rounded-2xl px-4 py-3 text-sm font-medium text-[#c8cac5] bg-[#151815] border border-[#23261f] hover:bg-[#1a1c18] hover:text-[#9fe870] hover:border-[#35501c] transition-all duration-200 <%= activeTag === tag ? 'bg-[#163300] text-[#9fe870] border-[#35501c] shadow-[0_0_18px_rgba(159,232,112,0.10)]' : '' %>"
              ><%= tag %></a>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  <% } %>
  <% } %>

  <!-- Posts Grid -->
  <div id="posts-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% posts.forEach(function(p) { %>
      <div class="post-card" data-title="<%= p.title.toLowerCase() %>" data-tags="<%= (p.tags || []).join(',').toLowerCase() %>" data-date="<%= p.createdAt %>">
        <%- include('../partials/post-card', { post: p }) %>
      </div>
    <% }); %>
  </div>

  <% if (!posts.length) { %>
    <p class="text-center text-[#868685] py-12">No posts found.</p>
  <% } %>
</div>

<script>
function filterPosts() {
  var search = document.getElementById('search-input').value.toLowerCase();
  var sort = document.getElementById('sort-select').value;
  var grid = document.getElementById('posts-grid');
  var cards = Array.from(grid.querySelectorAll('.post-card'));

  cards.forEach(function(card) {
    var title = card.dataset.title || '';
    var tags = card.dataset.tags || '';
    var match = title.includes(search) || tags.includes(search);
    card.style.display = match ? '' : 'none';
  });

  if (sort === 'oldest') {
    cards.sort(function(a, b) { return a.dataset.date.localeCompare(b.dataset.date); });
  } else {
    cards.sort(function(a, b) { return b.dataset.date.localeCompare(a.dataset.date); });
  }

  cards.forEach(function(card) { grid.appendChild(card); });
}

function toggleMoreTags() {
  var layer = document.getElementById('more-tags-layer');
  var btn = document.getElementById('more-tags-btn');
  var arrow = document.getElementById('more-tags-arrow');

  if (!layer) return;

  var isOpen = !layer.classList.contains('hidden');

  if (isOpen) {
    closeMoreTags();
    return;
  }

  layer.classList.remove('hidden');
  layer.classList.add('flex');
  document.body.style.overflow = 'hidden';
  if (arrow) arrow.style.transform = 'rotate(180deg)';
}

function closeMoreTags() {
  var layer = document.getElementById('more-tags-layer');
  var arrow = document.getElementById('more-tags-arrow');

  if (!layer) return;

  layer.classList.add('hidden');
  layer.classList.remove('flex');
  document.body.style.overflow = '';
  if (arrow) arrow.style.transform = 'rotate(0deg)';
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeMoreTags();
});
</script>