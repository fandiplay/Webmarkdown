<div class="max-w-3xl mx-auto px-6 py-12">
  <!-- Cover -->
  <% if (post.cover) { %>
    <img src="<%= post.cover %>" alt="<%= post.title %>" class="w-full aspect-video object-cover rounded-3xl mb-8" loading="lazy">
  <% } %>

  <!-- Meta -->
  <div class="flex flex-wrap items-center gap-3 mb-4">
    <% if (post.pinned) { %><span class="text-xs font-semibold text-[#b86700] bg-[#ffd11a]/20 px-2 py-0.5 rounded-full">Pinned</span><% } %>
    <span class="text-sm text-[#868685]"><%= post.createdAt %></span>
    <% if (post.updatedAt && post.updatedAt !== post.createdAt) { %><span class="text-sm text-[#868685]">Updated <%= post.updatedAt %></span><% } %>
    <span class="text-sm text-[#868685]">&middot; <%= post.readingTime %> min read</span>
    <span class="text-sm text-[#868685]">&middot; <%- post.written %></span>
  </div>

  <h1 class="text-[40px] font-black leading-[34px] text-[#0e0f0c] dark:text-[#e8ebe6] mb-4"><%= post.title %></h1>
  <p class="text-lg text-[#454745] dark:text-[#868685] mb-6"><%= post.description %></p>

  <!-- Tags -->
  <% if (post.tags && post.tags.length) { %>
    <div class="flex flex-wrap gap-2 mb-8">
      <% post.tags.forEach(function(tag) { %>
        <a href="/blog?tag=<%= tag %>" class="px-3 py-1 rounded-full text-xs font-semibold bg-[#e2f6d5] dark:bg-[#163300] text-[#054d28] dark:text-[#9fe870] hover:bg-[#c5edab] dark:hover:bg-[#1a3d00] transition-colors"><%= tag %></a>
      <% }); %>
    </div>
  <% } %>

  <hr class="border-[#e8ebe6] dark:border-[#1a1c18] mb-8">

  <!-- Content -->
  <article class="prose prose-lg dark:prose-invert max-w-none
    prose-headings:font-bold prose-headings:text-[#0e0f0c] dark:prose-headings:text-[#e8ebe6]
    prose-a:text-[#163300] dark:prose-a:text-[#9fe870] prose-a:font-medium
    prose-strong:text-[#0e0f0c] dark:prose-strong:text-[#e8ebe6]
    prose-code:before:content-none prose-code:after:content-none
    prose-img:rounded-3xl
    prose-blockquote:border-[#9fe870] prose-blockquote:text-[#454745] dark:prose-blockquote:text-[#c8cac5]">
    <%- post.html %>
  </article>

  <!-- Navigation -->
  <div class="flex justify-between mt-12 pt-8 border-t border-[#e8ebe6] dark:border-[#1a1c18]">
    <a href="/blog" class="text-[#0e0f0c] dark:text-[#e8ebe6] hover:text-[#163300] dark:hover:text-[#9fe870] transition-colors font-semibold">&larr; Back to Blog</a>
  </div>
</div>
