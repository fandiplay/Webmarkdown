<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Cover -->
  <% if (post.cover) { %>
    <img src="<%= post.cover %>" alt="<%= post.title %>" class="w-full aspect-video object-cover rounded-2xl mb-8 shadow-lg" loading="lazy">
  <% } %>

  <!-- Meta -->
  <div class="flex flex-wrap items-center gap-3 mb-4">
    <% if (post.pinned) { %><span class="text-xs font-semibold text-amber-600 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/40 px-2 py-0.5 rounded-full">Pinned</span><% } %>
    <span class="text-sm text-slate-500 dark:text-slate-400"><%= post.createdAt %></span>
    <% if (post.updatedAt && post.updatedAt !== post.createdAt) { %><span class="text-sm text-slate-400 dark:text-slate-500">Updated <%= post.updatedAt %></span><% } %>
    <span class="text-sm text-slate-400 dark:text-slate-500">&middot; <%= post.readingTime %> min read</span>
    <span class="text-sm text-slate-400 dark:text-slate-500">&middot; <%- post.written %></span>
  </div>

  <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4"><%= post.title %></h1>
  <p class="text-lg text-slate-500 dark:text-slate-400 mb-6"><%= post.description %></p>

  <!-- Tags -->
  <% if (post.tags && post.tags.length) { %>
    <div class="flex flex-wrap gap-2 mb-8">
      <% post.tags.forEach(function(tag) { %>
        <a href="/blog?tag=<%= tag %>" class="px-3 py-1 rounded-full text-xs font-medium bg-sky-50 dark:bg-sky-900/30 text-sky-600 dark:text-sky-400 hover:bg-sky-100 dark:hover:bg-sky-900/50 transition-colors"><%= tag %></a>
      <% }); %>
    </div>
  <% } %>

  <hr class="border-slate-200 dark:border-slate-700 mb-8">

  <!-- Content -->
  <article class="prose prose-lg dark:prose-invert max-w-none
    prose-headings:font-bold prose-headings:text-slate-800 dark:prose-headings:text-slate-100
    prose-a:text-sky-600 dark:prose-a:text-sky-400 prose-a:font-medium
    prose-strong:text-slate-800 dark:prose-strong:text-slate-200
    prose-code:before:content-none prose-code:after:content-none
    prose-img:rounded-xl
    prose-blockquote:border-sky-500 prose-blockquote:text-slate-600 dark:prose-blockquote:text-slate-400">
    <%- post.html %>
  </article>

  <!-- Navigation -->
  <div class="flex justify-between mt-12 pt-8 border-t border-slate-200 dark:border-slate-700">
    <a href="/blog" class="text-sky-600 dark:text-sky-400 hover:text-sky-700 dark:hover:text-sky-300 transition-colors font-medium">&larr; Back to Blog</a>
  </div>
</div>
