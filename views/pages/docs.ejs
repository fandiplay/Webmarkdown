<div class="max-w-6xl mx-auto px-6 py-12">
  <h1 class="text-[32px] font-semibold leading-[38.4px] tracking-[-0.96px] text-[#0e0f0c] dark:text-[#e8ebe6] mb-2">Documentation</h1>
  <p class="text-base text-[#454745] dark:text-[#868685] mb-8">Knowledge base and technical guides.</p>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% docs.forEach(function(doc) { %>
      <a href="/docs/<%= doc.slug %>" class="group block bg-white dark:bg-[#1a1c18] rounded-3xl p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
        <h3 class="text-lg font-bold text-[#0e0f0c] dark:text-[#e8ebe6] group-hover:text-[#163300] dark:group-hover:text-[#9fe870] transition-colors mb-2"><%= doc.title %></h3>
        <p class="text-sm text-[#454745] dark:text-[#868685] line-clamp-2"><%= doc.description %></p>
        <div class="flex flex-wrap gap-1.5 mt-3">
          <% (doc.tags || []).forEach(function(tag) { %>
            <span class="text-xs px-2 py-0.5 rounded-full bg-[#e8ebe6] dark:bg-[#2a2d25] text-[#454745] dark:text-[#868685]"><%= tag %></span>
          <% }); %>
        </div>
      </a>
    <% }); %>
  </div>

  <% if (!docs.length) { %>
    <p class="text-center text-[#868685] py-12">No documentation available yet.</p>
  <% } %>
</div>
