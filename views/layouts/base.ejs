<!DOCTYPE html>
<html lang="en" class="<%= locals.theme || '' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/seo') %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'] },
          animation: { fadeIn: 'fadeIn 0.3s ease-in-out' },
          keyframes: { fadeIn: { '0%': { opacity: 0, transform: 'translateY(4px)' }, '100%': { opacity: 1, transform: 'translateY(0)' } } }
        }
      }
    }
  </script>
  <script>
    (function() {
      var theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="icon" href="/static/favicon.ico">
  <style>
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .prose code { font-weight: 400; }
    .prose pre { background: transparent; padding: 0; margin: 0; }
    .prose pre code { background: transparent; padding: 0; }

    /* ── Prism theme (light) — Wise palette ── */
    .token.comment, .token.prolog, .token.doctype, .token.cdata { color: #868685; font-style: italic; }
    .token.punctuation { color: #868685; }
    .token.property, .token.tag, .token.boolean, .token.number, .token.constant, .token.symbol { color: #ffc091; }
    .token.selector, .token.attr-name, .token.builtin { color: #2ead4b; }
    .token.string, .token.char { color: #2ead4b; }
    .token.operator, .token.entity, .token.url { color: #163300; }
    .token.atrule, .token.attr-value, .token.keyword { color: #163300; }
    .token.function, .token.class-name { color: #ffc091; }
    .token.regex, .token.important, .token.variable { color: #d03238; }
    .token.important, .token.bold { font-weight: 700; }
    .token.italic { font-style: italic; }

    /* ── Prism theme (dark) ── */
    .dark .token.comment, .dark .token.prolog, .dark .token.doctype, .dark .token.cdata { color: #6b6b6a; }
    .dark .token.punctuation { color: #6b6b6a; }
    .dark .token.property, .dark .token.tag, .dark .token.boolean, .dark .token.number, .dark .token.constant, .dark .token.symbol { color: #ffc091; }
    .dark .token.selector, .dark .token.attr-name, .dark .token.builtin { color: #6ee7a0; }
    .dark .token.string, .dark .token.char { color: #6ee7a0; }
    .dark .token.operator, .dark .token.entity, .dark .token.url { color: #9fe870; }
    .dark .token.atrule, .dark .token.attr-value, .dark .token.keyword { color: #9fe870; }
    .dark .token.function, .dark .token.class-name { color: #ffc091; }
    .dark .token.regex, .dark .token.important, .dark .token.variable { color: #f87171; }

    /* ── Markdown refinements — Wise palette ── */
    .prose { --tw-prose-body: #454745; --tw-prose-headings: #0e0f0c; --tw-prose-links: #163300; --tw-prose-bold: #0e0f0c; --tw-prose-counters: #868685; --tw-prose-bullets: #c5edab; --tw-prose-hr: #e8ebe6; --tw-prose-quotes: #454745; --tw-prose-quote-borders: #9fe870; --tw-prose-captions: #868685; --tw-prose-code: #0e0f0c; --tw-prose-pre-code: #c5edab; --tw-prose-pre-bg: #0e0f0c; --tw-prose-th-borders: #c5edab; --tw-prose-td-borders: #e8ebe6; }
    .dark .prose { --tw-prose-body: #c8cac5; --tw-prose-headings: #e8ebe6; --tw-prose-links: #9fe870; --tw-prose-bold: #e8ebe6; --tw-prose-counters: #6b6b6a; --tw-prose-bullets: #3a3d35; --tw-prose-hr: #2a2d25; --tw-prose-quotes: #c8cac5; --tw-prose-quote-borders: #9fe870; --tw-prose-captions: #6b6b6a; --tw-prose-code: #e8ebe6; --tw-prose-pre-code: #c8cac5; --tw-prose-pre-bg: #1a1c18; --tw-prose-th-borders: #3a3d35; --tw-prose-td-borders: #2a2d25; }

    .prose th, .prose td { padding: 0.625rem 0.75rem; }
    .prose thead th { font-weight: 600; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; color: var(--tw-prose-counters); background: #e2f6d5; }
    .dark .prose thead th { background: #1a2a0a; }
    .prose tbody tr:hover { background: #e8ebe6; transition: background 0.15s; }
    .dark .prose tbody tr:hover { background: #1a1c18; }

    .prose h2 { padding-bottom: 0.5rem; border-bottom: 1px solid var(--tw-prose-hr); }
    .prose h3 { position: relative; padding-left: 0.75rem; }
    .prose h3::before { content: ''; position: absolute; left: 0; top: 0.25em; bottom: 0.25em; width: 3px; border-radius: 2px; background: #9fe870; }

    .prose blockquote { font-weight: 400; background: #e8ebe6; border-radius: 0.5rem; padding: 0.75rem 1.25rem; border-left-width: 4px; }
    .dark .prose blockquote { background: #1a1c18; }
    .prose blockquote p:first-of-type { margin-top: 0; }
    .prose blockquote p:last-of-type { margin-bottom: 0; }

    .prose hr { margin-top: 2.5rem; margin-bottom: 2.5rem; }

    .prose ul > li::marker { color: #9fe870; }
    .dark .prose ul > li::marker { color: #9fe870; }
    .prose ol > li::marker { color: #9fe870; font-weight: 600; }
    .dark .prose ol > li::marker { color: #9fe870; }

    .prose img { transition: transform 0.2s; }
    .prose img:hover { transform: scale(1.01); }

    .prose del { color: #868685; }
    .dark .prose del { color: #6b6b6a; }

    .prose .contains-task-list { list-style: none; padding-left: 0; }
    .prose .contains-task-list li { display: flex; align-items: flex-start; gap: 0.5rem; }
    .prose .contains-task-list input[type="checkbox"] { margin-top: 0.35rem; accent-color: #9fe870; }

    /* ── Animations ── */
    .prose > * { animation: fadeIn 0.35s ease-out both; }
    .prose > *:nth-child(1) { animation-delay: 0ms; }
    .prose > *:nth-child(2) { animation-delay: 30ms; }
    .prose > *:nth-child(3) { animation-delay: 60ms; }
    .prose > *:nth-child(4) { animation-delay: 90ms; }
    .prose > *:nth-child(5) { animation-delay: 120ms; }
    .prose > *:nth-child(6) { animation-delay: 150ms; }
    .prose > *:nth-child(7) { animation-delay: 180ms; }
    .prose > *:nth-child(8) { animation-delay: 210ms; }
    .prose > *:nth-child(9) { animation-delay: 240ms; }
    .prose > *:nth-child(n+10) { animation-delay: 270ms; }
  </style>
</head>
<body class="bg-[#e8ebe6] dark:bg-[#0e0f0c] text-[#0e0f0c] dark:text-[#e8ebe6] font-sans antialiased min-h-screen flex flex-col">
  <%- include('../partials/navbar') %>

  <main class="flex-1">
    <%- body %>
  </main>

  <%- include('../partials/footer') %>

  <script>
    lucide.createIcons();
  </script>
</body>
</html>
