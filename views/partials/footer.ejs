<footer class="bg-[#0e0f0c] dark:bg-[#0a0b09] text-[#c8cac5] text-sm">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p>&copy; <%= new Date().getFullYear() %> <%= config.fullName %>. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <% socials.forEach(function(s) { %>
          <a href="<%= s.url %>" target="_blank" rel="noopener noreferrer" class="text-[#868685] hover:text-[#9fe870] transition-colors duration-200" aria-label="<%= s.name %>">
            <i data-lucide="<%= s.icon %>" class="w-5 h-5"></i>
          </a>
        <% }); %>
      </div>
    </div>
  </div>
</footer>
