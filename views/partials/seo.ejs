<% if (locals.seo) { %>
  <title><%= seo.title ? seo.title + ' | ' + config.siteName : config.siteTitle %></title>
  <meta name="description" content="<%= seo.description || config.siteDescription %>">
  <link rel="canonical" href="<%= seo.canonical || (config.siteUrl + currentPath) %>">

  <!-- Open Graph -->
  <meta property="og:title" content="<%= seo.ogTitle || seo.title || config.siteTitle %>">
  <meta property="og:description" content="<%= seo.ogDescription || seo.description || config.siteDescription %>">
  <meta property="og:url" content="<%= seo.ogUrl || (config.siteUrl + currentPath) %>">
  <meta property="og:image" content="<%= seo.ogImage || seo.image || config.avatar %>">
  <meta property="og:type" content="<%= seo.ogType || 'website' %>">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="<%= seo.twitterCard || 'summary_large_image' %>">
  <meta name="twitter:title" content="<%= seo.twitterTitle || seo.ogTitle || seo.title || config.siteTitle %>">
  <meta name="twitter:description" content="<%= seo.twitterDescription || seo.ogDescription || seo.description || config.siteDescription %>">
  <meta name="twitter:image" content="<%= seo.twitterImage || seo.ogImage || seo.image || config.avatar %>">

  <!-- Article-specific -->
  <% if (seo.ogType === 'article') { %>
    <% if (seo.publishedTime) { %><meta property="article:published_time" content="<%= seo.publishedTime %>"><% } %>
    <% if (seo.modifiedTime) { %><meta property="article:modified_time" content="<%= seo.modifiedTime %>"><% } %>
    <% if (seo.author) { %><meta property="article:author" content="<%= seo.author %>"><% } %>
    <% if (seo.tags && seo.tags.length) { %>
      <% seo.tags.forEach(function(t) { %><meta property="article:tag" content="<%= t %>"><% }); %>
    <% } %>
  <% } %>
<% } else { %>
  <title><%= config.siteTitle %></title>
  <meta name="description" content="<%= config.siteDescription %>">
<% } %>
