<a href="/blog/<%= post.slug %>" class="group block bg-white dark:bg-[#1a1c18] rounded-3xl overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
  <% if (post.cover) { %>
    <div class="aspect-video overflow-hidden">
      <img src="<%= post.cover %>" alt="<%= post.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy">
    </div>
  <% } %>
  <div class="p-6">
    <div class="flex items-center gap-2 mb-2">
      <% if (post.pinned) { %><span class="text-xs font-semibold text-[#b86700] bg-[#ffd11a]/20 px-2 py-0.5 rounded-full">Pinned</span><% } %>
      <span class="text-xs text-[#868685]"><%= post.createdAt %></span>
      <span class="text-xs text-[#868685]">&middot; <%= post.readingTime %> min read</span>
    </div>
    <h3 class="text-lg font-bold text-[#0e0f0c] dark:text-[#e8ebe6] group-hover:text-[#163300] dark:group-hover:text-[#9fe870] transition-colors mb-2"><%= post.title %></h3>
    <p class="text-sm text-[#454745] dark:text-[#868685] line-clamp-2 mb-3"><%= post.description %></p>
    <div class="flex flex-wrap gap-1.5">
      <% (post.tags || []).forEach(function(tag) { %>
        <span class="text-xs px-2 py-0.5 rounded-full bg-[#e2f6d5] dark:bg-[#163300] text-[#054d28] dark:text-[#9fe870]"><%= tag %></span>
      <% }); %>
    </div>
  </div>
</a>
