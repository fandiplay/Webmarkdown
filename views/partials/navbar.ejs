<nav class="sticky top-0 z-50 bg-white/80 dark:bg-[#0e0f0c]/80 backdrop-blur-lg border-b border-[#e8ebe6] dark:border-[#1a1c18]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <img src="<%= config.avatar %>" alt="<%= config.fullName %>" class="w-9 h-9 rounded-full group-hover:ring-2 group-hover:ring-[#9fe870] transition-all duration-300">
        <span class="font-semibold text-sm text-[#0e0f0c] dark:text-[#e8ebe6]"><%= config.siteName %></span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        <% navigation.forEach(function(item) { %>
          <a href="<%= item.href %>" class="px-3 py-2 rounded-3xl text-sm font-semibold transition-all duration-200 <%= currentPath === item.href || (currentPath.startsWith(item.href) && item.href !== '/') ? 'bg-[#e2f6d5] dark:bg-[#163300] text-[#0e0f0c] dark:text-[#9fe870]' : 'text-[#454745] dark:text-[#868685] hover:bg-[#e8ebe6] dark:hover:bg-[#1a1c18] hover:text-[#0e0f0c] dark:hover:text-[#e8ebe6]' %>"><%= item.label %></a>
        <% }); %>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-2">
        <!-- Dark mode toggle -->
        <button id="theme-toggle" onclick="document.documentElement.classList.toggle('dark');localStorage.setItem('theme',document.documentElement.classList.contains('dark')?'dark':'light')" class="p-2 rounded-3xl text-[#454745] dark:text-[#868685] hover:bg-[#e8ebe6] dark:hover:bg-[#1a1c18] transition-all duration-200" aria-label="Toggle theme">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block dark:hidden"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden dark:block"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>

        <!-- Mobile hamburger -->
        <button id="menu-toggle" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" class="md:hidden p-2 rounded-3xl text-[#454745] dark:text-[#868685] hover:bg-[#e8ebe6] dark:hover:bg-[#1a1c18] transition-all duration-200" aria-label="Toggle menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <% navigation.forEach(function(item) { %>
        <a href="<%= item.href %>" class="block px-3 py-2 rounded-3xl text-sm font-semibold transition-all duration-200 <%= currentPath === item.href || (currentPath.startsWith(item.href) && item.href !== '/') ? 'bg-[#e2f6d5] dark:bg-[#163300] text-[#0e0f0c] dark:text-[#9fe870]' : 'text-[#454745] dark:text-[#868685] hover:bg-[#e8ebe6] dark:hover:bg-[#1a1c18]' %>"><%= item.label %></a>
      <% }); %>
    </div>
  </div>
</nav>
